generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String           @id @default(uuid())
  registerNo   String           @unique
  name         String
  password     String
  dob          String?          // Store actual DOB string for admin view/edit
  role         String           @default("STUDENT") // STUDENT or ADMIN
  batch        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  semesters    SemesterReport[]
  internships  Internship[]

  @@index([role])           // Speeds up admin findMany(where: { role: 'STUDENT' })
  @@index([role, batch])    // Speeds up batch-filtered queries
}

model SemesterReport {
  id             String         @id @default(uuid())
  semesterNumber Int
  sgpa           Float
  cgpa           Float
  overallGrade   String
  status         String         @default("Pass") // Pass or Fail
  fileName       String?
  fileUrl        String?
  isVerified     Boolean        @default(false)
  isRejected     Boolean        @default(false)
  apc            String?        // Attendance, Progress, and Conduct
  grievance      String?        // Student submitted grievance message/report if grades are incorrect
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects       SubjectGrade[]

  @@unique([userId, semesterNumber])
  @@index([userId])                    // Speeds up per-student semester lookups
  @@index([isVerified, isRejected])    // Speeds up pending queue filter
}

model SubjectGrade {
  id               String         @id @default(uuid())
  subjectCode      String
  subjectName      String
  grade            String
  gradePoint       Float
  credits          Float
  creditPoint      Float
  status           String         @default("Pass") // Pass or Fail
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  semesterReportId String
  semesterReport   SemesterReport @relation(fields: [semesterReportId], references: [id], onDelete: Cascade)

  @@index([semesterReportId])   // Critical: speeds up every JOIN when loading subject grades
}

model Internship {
  id          String   @id @default(uuid())
  courseName  String
  hours       Int
  fileName    String?
  fileUrl     String?
  isVerified  Boolean  @default(false)
  isRejected  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])                // Speeds up per-student internship lookups
  @@index([isVerified, userId])    // Speeds up pending internship queue
}
